{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    
    { "source": "/login", "destination": "/frontend/login/login.html" },
    { "source": "/signup", "destination": "/frontend/signup/signup.html" },
    { "source": "/events", "destination": "/frontend/events/events.html" },
    { "source": "/mypasses", "destination": "/frontend/mypasses/mypasses.html" },
    { "source": "/ticket", "destination": "/frontend/ticket/ticket.html" },
    { "source": "/admin/login", "destination": "/frontend/admin/login.html" },
    { "source": "/admin/dashboard", "destination": "/frontend/admin/dashboard.html" },
    { "source": "/admin/scan", "destination": "/frontend/admin/scan.html" },
    { "source": "/create-event", "destination": "/frontend/admin/create-event.html" },
    { "source": "/contact", "destination": "/frontend/contact/contact.html" },
    { "source": "/terms", "destination": "/frontend/legal/terms.html" },
    { "source": "/privacy", "destination": "/frontend/legal/privacy.html" },
    { "source": "/", "destination": "/landing-page/index.html" },
    
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}